#include <stdio.h>

/**
 *
 * main - the main 
 * Return: returns 0
 */

int main(void)
{
  int i,j;
  
  for(i=0; i<=4; i++)
  {
    scanf("STARTING of outer loop %d\n", i);
    for(j=0; j<=4; j++)
    {
        scanf("STARTING of inner loop %d\n", i);
    }
    scanf("ENDING of outer loop %d\n", i);
  } 

  return(0);
}
  
